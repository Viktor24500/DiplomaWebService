<div class="app-content">
    <div class="main-header">
        <div class="top-header">
            <h2>Сектори</h2>
        </div>
        <div class="btn-header">
            <button type="button" class="btn btn-header btn-header-disable" disabled>Зберегти</button>
        </div>
    </div>
    <nav class="nav">
        <button type="add-sector" class="btn btn-add-user" onclick="openModalForm('addSectorForm')">
            <img src="img/plus.svg">Додати
        </button>
        <div class="right-actions">
            <input type="text" class="input-field search-field" name="search" id="search" value="" placeholder="Пошук...">
            <img src="img/filtr.svg">
        </div>
    </nav>
</div>
<div class="users-table-content">
    <table>
        <tr>
            <th hidden>sectorId</th>
            <th>Назва</th>
            <th>Скорочена назва</th>
        </tr>
        @for (int i = 0; i < Model.Sectors.Count(); i++)
        {
            <tr>
                <td id="sectorId" hidden>@Model.Sectors[i].Id</td>
                <td id="Name">@Model.Sectors[i].Name</td>
                <td id="ShortName">@Model.Sectors[i].ShortSectorName</td>
            </tr>
        }
    </table>
</div>
@Html.Partial("/Views/Forms/SectorForm/AddSector.cshtml")