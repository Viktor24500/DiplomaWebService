@using DiplomaWebService.Models.Users
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model List<User>

@for (int i = 0; i < Model.Count(); i++)
{
    <tr>
        <td id="UserIdInTable" hidden>@Model[i].Id</td>
        <td id="UserNameInTable">@Model[i].UserName</td>
        <td id="LastNameInTable">@Model[i].LastName</td>
        <td id="FirstNameInTable">@Model[i].FirstName</td>
        <td id="FatherNameInTable">@Model[i].FatherName</td>
        <td id="UserNameInTable" class="status-@Model[i].StatusDescription">@Model[i].StatusDescription</td>
        <td id="IsActiveUserInTable">@Model[i].RoleName</td>
        <td>
            <button type="button" onclick="/users/disable/{@Model[i].Id}">
                <img src="img/trash.svg">
            </button>
        </td>
    </tr>
}