@using DiplomaWebService.Models.ViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model List<Contragent>
@for (int i = 0; i < @Model.Count(); i++)
{
	@if (Model[i].WhoAmI==false) 
	{
		<tr>
			<td id="contragentIdInTable" hidden>@Model[i].ContragentId</td>
			<td id="contragentNameInTable">@Model[i].ContragentName</td>
			<td id="parentIdInTable" hidden>@Model[i].ParentId</td>
			<td id="parentNameInTable">@Model[i].ParentName</td>
			<td id="contragentDescriptionInTable">@Model[i].ContragentDescription</td>
			<td id="IsActiveContragnetInTable" class="status-@Model[i].StatusDescription">@Model[i].StatusDescription</td>
			@* 					<td>
						<button type="button" onclick="/contragents/disable/{@Model[i].ContragentId}">
							<img src="img/trash.svg">
						</button>
					</td> *@
		</tr>
	}
}
