    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@using DiplomaWebService.Common.Enum
@using DiplomaWebService.Models.ViewModel.Invoice;
@model InvoiceOutViewModel
<div class="app-content">
    <div class="main-header">
        <div class="top-header">
            <h2>Накладні видача</h2>
        </div>
        <div class="btn-header">
            <button type="button" class="btn btn-header btn-header-disable" disabled>Зберегти</button>
        </div>
    </div>
    <nav class="nav">
        @if (Model.RoleId == (int)Roles.Viewer)
        {
            <button type="button" class="btn btn-add-user" onclick="openModalForm()" disabled>
                <img src="img/plus.svg">Додати
            </button>
        }
        else
        {
            <button type="button" class="btn btn-add-user" onclick="openModalForm()">
                <img src="img/plus.svg">Додати
            </button>
        }
		<div class="right-actions">
			<input type="text" class="input-field search-field" name="search" id="search" value="" placeholder="Пошук...">
			<img src="img/filtr.svg">
		</div>
	</nav>
</div>
<div class="users-table-content">
    <table>
        <thead>
            <tr>
                <th hidden>Invoice Id</th>
                <th>Дата</th>
                <th>Номер</th>
                <th hidden>Destination Id</th>
                <th>Відправник</th>
                <th hidden>Sender Id</th>
                <th>Отримувач</th>
                <th hidden>Invoice Type Id</th>
                <th>Тип накладної</th>
                <th hidden>Sector Id</th>
                <th>Служба</th>
                <th hidden>Document Type Id</th>
                <th>Тип документа</th>
                <th>Позиції</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.InvoicesOut.Count(); i++)
            {
                <tr>
                    <td hidden>@Model.InvoicesOut[i].Id</td>
                    <td>@Model.InvoicesOut[i].InvoiceDate.ToString("yyyy-MM-dd")</td>
                    <td>@Model.InvoicesOut[i].Number</td>
                    <td hidden>@Model.InvoicesOut[i].DestinationId</td>
                    <td>@Model.InvoicesOut[i].DestinationName</td>
                    <td hidden>@Model.InvoicesOut[i].SenderId</td>
                    <td>@Model.InvoicesOut[i].SenderName</td>
                    <td hidden>@Model.InvoicesOut[i].InvoiceType.Id</td>
                    <td>@Model.InvoicesOut[i].InvoiceType.Name</td>
                    <td hidden>@Model.InvoicesOut[i].Sector.Id</td>
                    <td>@Model.InvoicesOut[i].Sector.Name</td>
                    <td hidden>@Model.InvoicesOut[i].DocumentType.Id</td>
                    <td>@Model.InvoicesOut[i].DocumentType.Name</td>
                    <td>
                        <table>
                            <thead>
                                <tr>
                                    <th hidden>Item Id</th>
                                    <th>Назва</th>
                                    <th>Кількість</th>
                                    <th>Ціна</th>
                                    <th>Рік випуску</th>
                                    <th>Кількість</th>
                                    <th hidden>Unit Id</th>
                                    <th>Одиниці виміру</th>
                                    <th hidden>Category Id</th>
                                    <th>Категорія</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var position in Model.InvoicesOut[i].InvoicePositions)
                                {
                                    <tr>
                                        <td hidden>@position.Item.ItemId</td>
                                        <td>@position.Item.ItemName</td>
                                        <td>@position.Amount</td>
                                        <td>@position.Price</td>
                                        <td hidden>@position.SerialNumber</td>
                                        <td>@position.ProductionYear</td>
                                        <td hidden>@position.Unit.Id</td>
                                        <td>@position.Unit.Name</td>
                                        <td hidden>@position.Category.Id</td>
                                        <td>@position.Category.Name</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@Html.Partial("/Views/Forms/InvoiceForm/AddInvoiceOut.cshtml", Model)