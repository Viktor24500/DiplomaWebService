@using DiplomaWebService.Models;
@model List<Contragent>

@{
}

<table>
	<tr>
		<th class="hidden">contragentId</th>
		<th>Name</th>
		<th class ="hidden">parentId</th>
		<th>Parent name</th>
		<th>Status</th>
	<tr>
	@for (int i = 0; i < @Model.Count(); i++)
	{
		<tr>
			<td id="contragentId" class="hidden">@Model[i].ContragentId</td>
			<td id="contragentName">@Model[i].ContragentName</td>
			<td id="parentId" class="hidden">@Model[i].ParentId</td>
			<td id="parentName">@Model[i].ParentName</td>
			<td id="IsActive">@Model[i].IsActive</td>
		</tr>
	}
</table>