@using DiplomaWebService.Models;
@model List<Sector>

@{
}

<table>
	<tr>
		<th class="hidden">sectorId</th>
		<th>Name</th>
		<th>Short name</th>
	<tr>
	@for (int i = 0; i < @Model.Count(); i++)
	{
		<tr>
			<td id="sectorId" class="hidden">@Model[i].Id</td>
			<td id="Name">@Model[i].Name</td>
			<td id="Short name">@Model[i].ShortName</td>
		</tr>
	}
</table>