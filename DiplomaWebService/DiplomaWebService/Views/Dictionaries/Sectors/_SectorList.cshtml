@{
}

@model List<Sector>

@for (int i = 0; i < Model.Count(); i++)
{
    <tr class="data-table-tr">
        <td class="sectorId data-table-td" id="sectorId" hidden>@Model[i].Id</td>
        <td class="Name data-table-td" id="Name">@Model[i].Name</td>
        <td class="ShortName data-table-td" id="ShortName">@Model[i].ShortSectorName</td>
		<td class="data-table-td td-image">
			<div class="modal-popup">
				<div class="three-dots-button-container">
					<button onclick="openMenu(@i)">
						<img src="img/3dots.svg">
					</button>
				</div>
				<div class="modal-popup-container" id="modal-popup-hidden">
					<div class="menu-item-container">
						Редагувати
						<button class="small-icon-container" id="updateSector@i" onclick="FillSectorForm(@i)"><img src="img/edit.svg"></button>
					</div>
				</div>
			</div>
		</td>
    </tr>
}