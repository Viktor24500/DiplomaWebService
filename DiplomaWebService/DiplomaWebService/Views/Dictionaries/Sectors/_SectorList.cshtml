@{
}

@model List<Sector>

@for (int i = 0; i < Model.Count(); i++)
{
    <tr>
        <td id="sectorId" hidden>@Model[i].Id</td>
        <td id="Name">@Model[i].Name</td>
        <td id="ShortName">@Model[i].ShortSectorName</td>
    </tr>
}