@{
}
@using DiplomaWebService.Models;
@using DiplomaWebService.Models.Invoice
@model List<Invoice>
<div class="app-content">
	<div class="main-header">
		<div class="top-header">
			<h2>Накладні</h2>
		</div>
		<div class="btn-header">
			<button type="button" class="btn btn-header btn-header-disable" disabled>Зберегти</button>
		</div>
	</div>
	<nav class="nav">
		<button type="add-user" class="btn btn-add-user" onclick="openModalForm()">
			<img src="img/admin.svg">Додати
		</button>
		<div class="right-actions">
			<input type="text" class="input-field search-field" name="search" id="search" value="" placeholder="Пошук...">
			<img src="img/filtr.svg">
		</div>
	</nav>
</div>
<div class="users-table-content">
    <table>
        <thead>
            <tr>
                <th hidden>Invoice ID</th>
                <th>Invoice Date</th>
                <th>Number</th>
                <th hidden>Destination ID</th>
                <th>Destination Name</th>
                <th hidden>Sender ID</th>
                <th>Sender Name</th>
                <th hidden>Invoice Type ID</th>
                <th>Invoice Type</th>
                <th hidden>Sector ID</th>
                <th>Sector</th>
                <th hidden>Document Type ID</th>
                <th>Document Type</th>
                <th>Positions</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count(); i++)
            {
                <tr>
                    <td hidden>@Model[i].Id</td>
                    <td>@Model[i].InvoiceDate.ToString("yyyy-MM-dd")</td>
                    <td>@Model[i].Number</td>
                    <td hidden>@Model[i].DestinationId</td>
                    <td>@Model[i].DestinationName</td>
                    <td hidden>@Model[i].SenderId</td>
                    <td>@Model[i].SenderName</td>
                    <td hidden>@Model[i].InvoiceType.Id</td>
                    <td>@Model[i].InvoiceType.Name</td>
                    <td hidden>@Model[i].Sector.Id</td>
                    <td>@Model[i].Sector.Name</td>
                    <td hidden>@Model[i].DocumentType.Id</td>
                    <td>@Model[i].DocumentType.Name</td>
                    <td>
                        <table>
                            <thead>
                                <tr>
                                    <th hidden>Item ID</th>
                                    <th>Item</th>
                                    <th>Amount</th>
                                    <th>Price</th>
                                    <th hidden>Unit ID</th>
                                    <th>Unit</th>
                                    <th hidden>Category ID</th>
                                    <th>Category</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var position in Model[i].InvoicePositions)
                                {
                                    <tr>
                                        <td hidden>@position.Item.ItemId</td>
                                        <td>@position.Item.ItemName</td>
                                        <td>@position.Amount</td>
                                        <td>@position.Price</td>
                                        <td hidden>@position.Unit.Id</td>
                                        <td>@position.Unit.Name</td>
                                        <td hidden>@position.Category.Id</td>
                                        <td>@position.Category.Name</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>