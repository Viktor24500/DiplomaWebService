<form action="/items" method="post" class="modal" id="addItemForm">
    <div class="user-modal-header">
        <button class="small-icon-container close-btn" type="button" onclick="closeModalForm()">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2.05808 15.59C1.1359 15.59 0.405029 14.8587 0.405029 13.9188C0.405029 13.501 0.579034 13.0832 0.90962 12.7698L5.64237 8.01742L0.90962 3.28238C0.579034 2.96907 0.405029 2.55127 0.405029 2.13348C0.405029 1.19342 1.1359 0.479631 2.05808 0.479631C2.54525 0.479631 2.92799 0.636408 3.24127 0.949721L7.99132 5.68477L12.7588 0.932288C13.1068 0.601542 13.4723 0.444885 13.942 0.444885C14.8642 0.444885 15.595 1.17599 15.595 2.09862C15.595 2.53384 15.421 2.91677 15.0905 3.26495L10.3577 8.01742L15.0905 12.7523C15.4036 13.0832 15.5776 13.4836 15.5776 13.9188C15.5776 14.8587 14.8468 15.59 13.9073 15.59C13.4374 15.59 13.0372 15.4159 12.7067 15.1026L7.99132 10.3849L3.276 15.1026C2.96284 15.4333 2.54525 15.59 2.05808 15.59Z" fill="#768B63" />
            </svg>
        </button>
        <div class="top-header">
            <h2>Новий предмет</h2>
        </div>
    </div>
    <div class="user-modal-content">
        <div class="user-modal-block">
            <div class="user-modal-label" hidden>Id:</div>
            <div class="input-field-wrapper">
                <input type="text" class="input-field hidden" id="itemIdForm" name="Id" placeholder="Id" hidden>
                <div class="separator" hidden></div>
            </div>
        </div>
        <div class="user-modal-block">
            <div class="user-modal-label">Назва: *</div>
            <div class="input-field-wrapper">
                <input type="text" class="input-field" id="itemNameForm" name="name" placeholder="Назва" value="" required>
                <div class="separator"></div>
            </div>
        </div>
        <div class="user-modal-block">
            <div class="user-modal-label">Номенклатурний номер:</div>
            <div class="input-field-wrapper">
                <input type="text" class="input-field" id="nomenclatureNumberForm" name="nomenclatureNumber" placeholder="Номенклатурний номер" value="">
                <div class="separator"></div>
            </div>
        </div>
        <div class="user-modal-block">
            <div class="user-modal-label">Служба: *</div>
            <div class="input-field-wrapper">
                <select class="input-field dropdown" id="sectorIdForm" name="sectorId" required>
                    @for (int i = 0; i < @Model.Sectors.Count; i++)
                    {
                        <option value="@Model.Sectors[i].Id">@Model.Sectors[i].Name</option>
                    }
                </select>
                <div class="separator"></div>
            </div>
        </div>
        <div class="user-modal-block">
            <div class="user-modal-label">Одиниці виміру: *</div>
            <div class="input-field-wrapper">
                <select class="input-field dropdown" id="unitIdForm" name="unitId" required>
                    @for (int i = 0; i < @Model.Units.Count; i++)
                    {
                        <option value="@Model.Units[i].Id">@Model.Units[i].Name</option>
                    }
                </select>
                <div class="separator"></div>
            </div>
        </div>
        <div class="user-modal-block">
            <div class="user-modal-label">Вага:</div>
            <div class="input-field-wrapper">
                <input type="number" class="input-field" id="weightForm" name="weight" placeholder="Вага" value="" min="0">
                <div class="separator"></div>
            </div>
        </div>
        <div class="user-modal-block">
            <div class="user-modal-label">Штат:</div>
            <div class="input-field-wrapper">
                <input type="number" class="input-field" id="requiredQuantityForm" name="requiredQuantity" placeholder="Штат" value="" min="0">
                <div class="separator"></div>
            </div>
        </div>
        <div class="user-modal-block">
            <div class="user-modal-label">Опис</div>
            <div class="input-field-wrapper">
                <input type="text" class="input-field comment" id="itemDescriptionForm" name="description" placeholder="Опис" value="">
                <div class="separator"></div>
            </div>
        </div>
    </div>
    <div class="user-modal-footer">
        <button type="submit" id="submitButton" class="btn btn-modal">Зберегти</button>
    </div>
</form>