@using DiplomaWebService.Models.Invoice.Out
@using DiplomaWebService.Models.ViewModel.Invoice.Out
@model InvoiceOutViewModelInvoice
<div class="main-header">
    <div class="top-header">
        <h2>Накладні видача @Model.InvoicesOut.Number</h2>
    </div>
    <div class="btn-header">
        <button type="button" class="btn btn-header btn-header-disable" disabled>Зберегти</button>
    </div>
</div>
<nav class="nav">
    <a href="/invoicesOut" class="btn btn-add-user">
        <img src="../img/back.svg">
    </a>
</nav>
<div class="container">
    <div class="block-container ">
        <span>Дата @Model.InvoicesOut.InvoiceDate</span>
        <span hidden>Sender Id @Model.InvoicesOut.SenderId</span>
        <div class="separator"></div>
        <span>Відправник @Model.InvoicesOut.SenderName</span>
        <span hidden>Destination Id @Model.InvoicesOut.DestinationId</span>
        <div class="separator"></div>
        <span>Отримувач @Model.InvoicesOut.DestinationName</span>
        <span hidden>Sector Id @Model.InvoicesOut.Sector.Id</span>
        <div class="separator"></div>
        <span>Служба @Model.InvoicesOut.Sector.Name</span>
    </div>
</div>
<div class="container">
    <div class="block-container ">
        Позиції
        <button type="button" class="btn btn-add-user" onclick="openModalForm()" disabled>
            <img src="../img/plus.svg">Додати
        </button>
    </div>
</div>
<div class="users-table-content">
    <table>
        <thead>
            <tr>
                <th hidden>Item Id</th>
                <th>Назва</th>
                <th>Серійний номер</th>
                <th>Рік випуску</th>
                <th>Кількість</th>
                <th>Ціна</th>
                <th hidden>Unit Id</th>
                <th>Одиниці виміру</th>
                <th hidden>Category Id</th>
                <th>Категорія</th>
            </tr>
        </thead>
        <tbody>
            @foreach (InvoicePositionOut position in Model.InvoicesOut.InvoicePositions)
            {
                <tr>
                    <td hidden>@position.Item.ItemId</td>
                    <td>@position.Item.ItemName</td>
                    <td>@position.SerialNumber</td>
                    <td>@position.ProductionYear</td>
                    <td>@position.Amount</td>
                    <td>@position.Price</td>
                    <td hidden>@position.Unit.Id</td>
                    <td>@position.Unit.Name</td>
                    <td hidden>@position.Category.Id</td>
                    <td>@position.Category.Name</td>
                </tr>
            }
        </tbody>
    </table>
</div>