@using DiplomaWebService.Models.ViewModel
@model UnitViewModel
@{
}

<div class="app-content">
	<div class="main-header">
		<div class="top-header">
			<h2>Одиниці виміру</h2>
		</div>
		<div class="btn-header">
			<button type="button" class="btn btn-header btn-header-disable" disabled>Зберегти</button>
		</div>
	</div>
	<nav class="nav">
		<button type="add-user" class="btn btn-add-user" onclick="openModalForm('addUnitForm')">
			<img src="img/plus.svg">Додати
		</button>
		<div class="right-actions">
			<input type="text" class="input-field search-field" name="search" id="search" value="" placeholder="Пошук...">
			<img src="img/filtr.svg">
		</div>
	</nav>
</div>
<div class="users-table-content">
    <table>
		<thead>
			<tr>
				<th hidden>UnitId</th>
				<th>Назва</th>
			</tr>
		</thead>
		<tbody>
			@for (int i = 0; i < Model.Units.Count; i++)
			{
				<tr>
					<td id="unitId" hidden>@Model.Units[i].Id</td>
					<td id="unitName">@Model.Units[i].Name</td>
				</tr>
			}
		</tbody>
    </table>
</div>
@Html.Partial("/Views/Forms/UnitForm/AddUnit.cshtml")