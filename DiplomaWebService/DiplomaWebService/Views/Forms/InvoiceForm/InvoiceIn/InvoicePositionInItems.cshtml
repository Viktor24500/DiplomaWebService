@using DiplomaWebService.Models.Items
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model List<Item>
@for (int i=0; i<Model.Count; i++)
{
    <tr>
        <td hidden class="invoice-position-table-items-item-id">@Model[i].ItemId</td>
        <td class="invoice-position-table-items-item-name">@Model[i].ItemName</td>
        <td hidden class="invoice-position-table-items-unit-id">@Model[i].Unit.Id</td>
        <td class="invoice-position-table-items-unit-name">@Model[i].Unit.Name</td>
        <td><input type="checkbox" class="invoice-position-item-checkbox" value="@i"/></td>
    </tr>
}