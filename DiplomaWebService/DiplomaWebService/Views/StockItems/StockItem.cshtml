@using DiplomaWebService.Models.ViewModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model StockItemViewModel
<div class="app-content">
	<div class="main-header">
		<div class="top-header">
			<h2>Майно на обліку</h2>
		</div>
		<div class="btn-header">
			<button type="button" class="btn btn-header btn-header-disable" disabled>Зберегти</button>
		</div>
	</div>
	<nav class="nav">
		<button type="add-user" class="btn btn-add-user" onclick="ReassessmentWithCoeffOpen()">
			<img src="img/reevaluation.svg">Коефіціент
		</button>		
		<div class="right-actions">
			<input type="text" class="input-field search-field" name="search" id="search" value="" placeholder="Пошук..." onkeydown="searchStockItem(event)">
			<button onclick="openFilter()">
				<img src="img/filtr.svg">
			</button>
		</div>
		<div class="modal-popup-container-filters" id="modal-popup-hidden-filters">
			<form action="/filterStockItems" method="get" class="modal-filters" id="filterForm">
				<label>Служби</label><br>
				@for (int i = 0; i < Model.Sectors.Count; i++)
				{
					<input type="checkbox" id="checkboxFilter@i" name="sector" class="sector-checkbox" value=@Model.Sectors[i].Id />
					<label for="sector">@Model.Sectors[i].Name</label>

					<br>
				}
				<label>Підрозділи</label><br>
				@for (int i = 0; i < Model.Contragents.Count; i++)
				{
					<input type="checkbox" id="checkboxFilter@i" name="contragent" class="sector-checkbox" value=@Model.Contragents[i].ContragentId />
					<label for="contragent">@Model.Contragents[i].ContragentName</label>

					<br>
				}
				<button type="submit" id="submitButtonFilters" class="btn btn-modal">Примінити</button>
			</form>
		</div>
	</nav>
</div>
<div class="users-table-content">
	<table class="data-table">
		<thead class="data-table-thead">
			<tr class="data-table-tr">
				<th class="data-table-th" hidden>stockItemId</th>
				<th class="data-table-th" hidden>ItemId</th>
				<th class="data-table-th">Майно</th>
				<th class="data-table-th">Номенклатурний номер</th>
				<th class="data-table-th">Рік випуску</th>
				<th class="data-table-th" hidden>UnitId</th>
				<th class="data-table-th">Одиниця виміру</th>
				<th class="data-table-th" hidden>CategoryId</th>
				<th class="data-table-th">Категорія</th>
				<th class="data-table-th">Ціна</th>
				<th class="data-table-th">Кількість</th>
				<th class="data-table-th">Підрозділ</th>
				<th class="data-table-th"></th>
			</tr>
		<thead>
		<tbody id="stockItemList" class="scroll">
				@Html.Partial("/Views/StockItems/_StockItemList.cshtml", @Model.StockItems)
		</tbody>
	</table>
</div>
@Html.Partial("/Views/Forms/StockItemForm/ReassessmentWithCoefForm.cshtml", @Model)
@Html.Partial("/Views/Forms/StockItemForm/ReassessmentWithoutCoefForm.cshtml", @Model)