@*@{
} *@
@using DiplomaWebService.Models;
@model List<Role>

<div class="newUserForm">
    <form action="/users" method="post" id="addUser">
        <label for="username">Username </label>
        <input type="text" class="UserInput" id="username" name="username" value="" placeholder="login" required><br>
        <label for="password">Password </label>
        <input type="text" class="UserInput" id="password" name="password" value="" placeholder="password" required><br><br>
        <label for="email">Email </label>
        <input type="text" class="UserInput" id="email" name="email" value="" placeholder="Email" required><br><br>
        <label for="firstName">First Name </label>
        <input type="text" class="UserInput" id="firstName" name="firstName" value="" placeholder="firstName" required><br><br>
        <label for="lastName">Last Name </label>
        <input type="text" class="UserInput" id="lastName" name="lastName" value="" placeholder="lastName" required><br><br>
        <label for="fatherName">Father Name </label>
        <input type="text" class="UserInput" id="fatherName" name="fatherName" value="" placeholder="fatherName"><br><br>
        <label for="role">Role </label>
        <select name="roles" id="roles" form="addUser">
            @for (int i = 0; i < @Model.Count(); i++)
            {
                <option value="@Model[i].Id"> @Model[i].Name</option>
            }
        </select><br><br>
        <input type="submit" class="formButton" id="submit" value="Submit">
    </form>
</div>