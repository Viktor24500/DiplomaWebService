@using DiplomaWebService.Models.Items;
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@model List<Item>

@for (int i = 0; i < Model.Count(); i++)
{
	<tr>
		<td id="itemId" hidden>@Model[i].ItemId</td>
		<td id="name">@Model[i].ItemName</td>
		<td id="inventoryNumber">@Model[i].NomenclatureNumber</td>
		<td id="unitId" hidden>@Model[i].Unit.Id</td>
		<td id="unitName">@Model[i].Unit.Name</td>
		<td id="reuiredQuantity">@Model[i].RequiredQuantity</td>
		<td id="weight">@Model[i].Weight</td>
		<td id="description">@Model[i].Description</td>
		<td id="sectorId" hidden>@Model[i].Sector.Id</td>
		<td id="sectorName">@Model[i].Sector.Name</td>
	</tr>
}